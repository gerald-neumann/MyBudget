# On the NAS, copy this file next to docker-compose.yml as either:
#   .env                 — standard Docker Compose variable substitution, or
#   docker-compose.env   — Synology Container Manager often expects this exact name/path
#     (error "Failed to load ... docker-compose.env" means create that file here, e.g. copy this file and rename).

# Web UI (avoid 8080 if Keycloak uses it on the same host; DSM often uses 5000/5001).
JENKINS_HTTP_HOST_PORT=8095

# Inbound agents (optional; default Jenkins port inside the container is 50000).
JENKINS_AGENT_HOST_PORT=50000

# JVM heap for the controller (MB). Tune for your NAS RAM.
JENKINS_JAVA_HEAP_MB=1024

TZ=Europe/Berlin

# Host `docker` group id: on the NAS run `getent group docker` (third field). If unset or 0, compose runs Jenkins as root for socket access.
# DOCKER_GID=237

# Optional bind mount for SSH keys used by Jenkins jobs (uncomment volume in docker-compose.yml).
# JENKINS_SSH_DIR=/volume1/docker/jenkins-ssh
