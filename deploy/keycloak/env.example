# Copy to .env next to docker-compose.yml, or run New-KeycloakDeploymentPackage.ps1
#
# Public base URL of Keycloak (no trailing slash). Must match what browsers use, e.g. DSM reverse proxy:
#   https://auth.mybudget.example.com
KEYCLOAK_HOSTNAME=https://auth.mybudget.example.com

# Host port published to Synology (reverse proxy destination http://127.0.0.1:THIS_PORT)
KEYCLOAK_HTTP_PORT=8080

# Initial Keycloak admin bootstrap user (admin console; change after first login)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin

# PostgreSQL password for the dedicated Keycloak database user
KEYCLOAK_DB_PASSWORD=change-me-db
