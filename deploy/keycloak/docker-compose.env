# Optional alternate env filename: place next to docker-compose.yml as either:
#   .env                    (Docker Compose default), or
#   docker-compose.env      (some UIs expect this exact name — copy/rename as needed).
#
# PostgreSQL files live on disk at KEYCLOAK_PGDATA_HOST. Recreating the stack does not
# delete that folder — back it up if you want restores to keep IdP data.
#
# Replace CHANGE_ME_* before first start.

KEYCLOAK_HOSTNAME=https://auth.ispark.diskstation.me
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_PGDATA_HOST=/volume1/docker/keycloak/pgdata

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN
KEYCLOAK_DB_PASSWORD=CHANGE_ME_KEYCLOAK_DB
