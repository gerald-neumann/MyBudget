# Copy to .env next to docker-compose.yml, or run New-SynologyDeploymentPackage.ps1

# --- App PostgreSQL (EF Core / API) ---
POSTGRES_DB=my_budget
POSTGRES_USER=mybudget
POSTGRES_PASSWORD=change-me-app-db

# --- Published host ports (avoid DSM defaults 5000/5001) ---
API_HOST_PORT=5256
UI_HOST_PORT=9080

# --- MyBudget API/UI Docker images (docker-compose.images.yml; tags must stay lowercase) ---
MYBUDGET_API_IMAGE=mybudget-api:local
MYBUDGET_UI_IMAGE=mybudget-ui:local

# --- API auth & CORS (see root README.md) ---
# Use false until Keycloak realm and clients exist; then set true and HTTPS metadata as needed.
AUTH_ENABLED=false
AUTH_AUTHORITY=https://auth.example.com/realms/my-budget
AUTH_AUDIENCE=my-budget-api
AUTH_REQUIRE_HTTPS_METADATA=true
# Browser origin for the Angular app (CORS). Example: https://app.example.com or http://diskstation:9080
FRONTEND_ORIGIN=http://localhost:9080

# --- Keycloak (same variables as deploy/keycloak/env.example) ---
KEYCLOAK_HOSTNAME=https://auth.example.com
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin
KEYCLOAK_DB_PASSWORD=change-me-keycloak-db
