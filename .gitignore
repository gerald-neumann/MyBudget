# --- Portainer / local Docker junk ---
# Typical bind-mount folder names for Portainer CE data (never commit)
portainer_data/
portainer-data/
# Local-only compose overrides
docker-compose.override.yml

# --- Docker image bundles (offline / scp deploy) ---
*-app-images.tar

# Shared build stamp (generated by scripts/stamp-build-info.cjs for consolidated builds)
BUILD_TIMESTAMP_UTC

# --- Secrets & local env (keep *.example committed) ---
.env
.env.local
.env.*.local
!.env.example

# Optional: one-line Portainer API token for Deploy-PortainerMyBudgetStack.ps1 (prefer $env:USERPROFILE\.secrets\…)
deploy/portainer/.portainer-access-token

# Local receipt/invoice blob storage (dev file backend)
backend/MyBudget.Api/Data/actual-entry-attachments/

# Agent / local compile scratch (never commit)
_agent_verify_build*/
_agent_build*/
_compile_check_out*/
_compile_check_out2*/

