# Production Keycloak for MyBudget @ flowparity.com
# Copy to deploy/keycloak/.env (gitignored), set passwords and KEYCLOAK_PGDATA_HOST, then deploy via Portainer
# or: pwsh ./deploy/portainer/Deploy-PortainerKeycloakStack.ps1 -EndpointId <id> -SkipCertificateCheck
#
# Reverse proxy: https://auth.flowparity.com → http://127.0.0.1:<KEYCLOAK_HTTP_PORT>
# Forward X-Forwarded-Proto (https) and X-Forwarded-Host (auth.flowparity.com). See deploy/portainer/PORTAINER-FLOWPARITY-DEPLOY.md §6.4.

KEYCLOAK_HOSTNAME=https://auth.flowparity.com
KC_HTTP_RELATIVE_PATH=/keycloak

KEYCLOAK_HTTP_PORT=8081

# Absolute path on the Docker host for PostgreSQL data (create empty folder before first start).
KEYCLOAK_PGDATA_HOST=/opt/stacks/flowparity-keycloak/pgdata

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN
KEYCLOAK_DB_PASSWORD=CHANGE_ME_KEYCLOAK_DB
