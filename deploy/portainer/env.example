# Copy into Portainer → Stack → Environment variables (or .env beside compose on the host).
#
# For Deploy-PortainerMyBudgetStack.ps1 on your PC: you MAY put a Portainer personal access token in a gitignored
# deploy/portainer/.env — keys below are read locally and stripped before the stack env is sent to Portainer.
#
# Without the 1Password CLI (`op`), use the plain token line (uncomment and paste ptr_... from Portainer → Account):
# MYBUDGET_PORTAINER_ACCESS_TOKEN=ptr_...
#
# With `op signin`, you can use instead:
# MYBUDGET_PORTAINER_ACCESS_TOKEN_OP_REF=op://Vault/Item/credential
# MYBUDGET_PORTAINER_PASSWORD_OP_REF=op://Vault/Item/password
# MYBUDGET_PORTAINER_PASSWORD=...
# MYBUDGET_PORTAINER_DEFAULT_ACCESS_TOKEN_OP_REF=op://OtherVault/OtherItem/password   # overrides script default 1Password ref
# MYBUDGET_PORTAINER_BASE_URL=https://portainer.other.example

# --- Host: create external Docker network once (required for edge proxy → mybudget hostname) ---
# docker network create edge

# --- PostgreSQL ---
POSTGRES_DB=my_budget
POSTGRES_USER=mybudget
POSTGRES_PASSWORD=change-me-strong-password

# --- Docker images (build/push or docker load before first deploy) ---
MYBUDGET_API_IMAGE=mybudget-api:local
MYBUDGET_UI_IMAGE=mybudget-ui:local

# Path on the Portainer host to ui-config.json bind-mounted into the UI container.
MYBUDGET_UI_CONFIG_PATH=./ui-config.json

# --- UI nginx optional Keycloak facade ---
# If you use same-domain facade /auth, keep these values in sync with your Keycloak upstream.
MYBUDGET_KEYCLOAK_UPSTREAM_ORIGIN=https://auth.flowparity.com
# If Keycloak serves under https://auth.../keycloak, keep /keycloak.
# If Keycloak serves at root https://auth.../, set empty value.
MYBUDGET_KEYCLOAK_UPSTREAM_BASE_PATH=/keycloak

# --- API: path prefix behind nginx (must match edge location /api/) ---
PUBLIC_PATH_BASE=/api

# --- API auth (shared Keycloak host/issuer) ---
ASPNETCORE_ENVIRONMENT=Production
AUTH_ENABLED=true
AUTH_AUTHORITY=https://auth.flowparity.com/keycloak/realms/my-budget
# Optional explicit OIDC metadata URL (set this if Keycloak is behind a path-rewriting proxy).
# Example: https://auth.flowparity.com/keycloak/realms/my-budget/.well-known/openid-configuration
AUTH_METADATA_ADDRESS=
# Optional additional accepted issuers (only if the token `iss` differs from AUTH_AUTHORITY).
AUTH_VALID_ISSUER_0=
AUTH_VALID_ISSUER_1=
AUTH_AUDIENCE=my-budget-api
AUTH_REQUIRE_HTTPS_METADATA=true
# Exact browser origin of the SPA (CORS); no /api suffix here
FRONTEND_ORIGIN=https://mybudget.flowparity.com
ENABLE_SWAGGER=false
# Second guard for Swagger in production. Keep false unless you intentionally need docs temporarily.
SWAGGER_ALLOW_IN_PRODUCTION=false

# --- How the UI container (nginx) is published (host:container, full spec; do not append :80 elsewhere) ---
# If deploy fails with "port is already allocated", another container is using that host port — see PORTAINER-FLOWPARITY-DEPLOY.md §2.5.
# Production with host TLS (see PORTAINER-FLOWPARITY-DEPLOY.md §2.1): bind loopback only, e.g.
# MYBUDGET_EDGE_PUBLISH=80:80   # only when no host-level TLS proxy is used
MYBUDGET_EDGE_PUBLISH=127.0.0.1:18080:80
