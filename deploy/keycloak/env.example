# Copy to .env next to docker-compose.yml (see also docker-compose.env for a filled-out template shape).
#
# Public base URL of Keycloak (no trailing slash). Must match what browsers use, e.g. your reverse proxy / TLS hostname:
#   https://auth.mybudget.example.com
KEYCLOAK_HOSTNAME=https://auth.mybudget.example.com

# HTTP context path for Keycloak 26+ (Quarkus). Omit this line for root path (URLs like …/realms/my-budget).
# For https://auth.example.com/keycloak/… set KC_HTTP_RELATIVE_PATH=/keycloak (see flowparity.env.example).

# Host port published on the Docker host (reverse proxy destination http://127.0.0.1:THIS_PORT).
KEYCLOAK_HTTP_PORT=8081

# Initial Keycloak admin bootstrap user (admin console; change after first login)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin

# PostgreSQL password for the dedicated Keycloak database user
KEYCLOAK_DB_PASSWORD=change-me-db

# PostgreSQL data directory on the Docker host (bind mount). Create an empty folder before first start.
# Data survives container/project delete as long as this host folder is kept (not a Docker named volume).
# Absolute path on the host, e.g. /opt/stacks/keycloak/pgdata
# Or relative to this compose file, e.g. ./pgdata (folder "pgdata" beside docker-compose.yml).
KEYCLOAK_PGDATA_HOST=/volume1/docker/keycloak/pgdata
