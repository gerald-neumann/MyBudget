// Multibranch: set Script Path to deploy/jenkins/Jenkinsfile
//
// Builds API/UI images on the NAS Docker engine (host socket from Jenkins container).
// Deploy uses a folder ON THE NAS (not the ephemeral workspace): compose bind-mounts
// (e.g. ./ui-config.json) must exist on the Docker host. Mount that folder into the
// Jenkins container at the same path (see deploy/jenkins-synology/docker-compose.yml).

pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  environment {
    // NAS directory that contains docker-compose.images.yml, .env, ui-config.json.
    // Override in the multibranch job (or folder) if needed: MYBUDGET_DEPLOY_DIR=/volume1/...
    MYBUDGET_DEPLOY_DIR = "${env.MYBUDGET_DEPLOY_DIR ?: '/volume1/docker/mybudget'}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build images') {
      steps {
        dir("${WORKSPACE}") {
          sh '''
            docker build -f backend/MyBudget.Api/Dockerfile -t mybudget-api:ci .
            docker build -f frontend/my-budget-ui/Dockerfile -t mybudget-ui:ci .
          '''
        }
      }
    }

    stage('Deploy stack') {
      steps {
        script {
          def d = env.MYBUDGET_DEPLOY_DIR
          if (!fileExists("${d}/docker-compose.images.yml")) {
            echo "Skipping deploy: ${d}/docker-compose.images.yml not found inside this Jenkins container."
            echo "Mount your Synology deploy folder at ${d} (host path = container path), or set MYBUDGET_DEPLOY_DIR."
          } else if (!fileExists("${d}/.env")) {
            echo "Skipping deploy: ${d}/.env missing (copy from deploy/synology on the NAS)."
          } else {
            dir(d) {
              sh '''
                export MYBUDGET_API_IMAGE=mybudget-api:ci
                export MYBUDGET_UI_IMAGE=mybudget-ui:ci
                docker compose -f docker-compose.images.yml pull || true
                docker compose -f docker-compose.images.yml up -d --no-build
              '''
            }
          }
        }
      }
    }
  }
}
